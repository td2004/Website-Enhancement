# Copy this file to `.env` for local serverless development.
# DO NOT commit a real .env file to git.

# Financial Modeling Prep API key (used by api/stocks.js)
# Get one at https://site.financialmodelingprep.com/
FMP_API_KEY=

# OpenAI API key (used by api/rag.js for the Portfolio RAG Assistant).
# Optional — without it the assistant falls back to on-device retrieval and
# still works. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key (used by api/agent.js for the Portfolio AI Agent).
# Required for the agent to run — without it /api/agent returns 503 and the
# demo shows a "not configured" notice. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
